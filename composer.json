{
    "name": "ospp/station-simulator",
    "description": "OSPP Station Simulator — simulates 1-N self-service stations via MQTT for UAT/load testing",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel-zero/framework": "^12.0",
        "ospp/protocol": "^0.2.1",
        "php-mqtt/client": "^2.1",
        "react/event-loop": "^1.5",
        "react/socket": "^1.15",
        "cboden/ratchet": "^0.4",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "opis/json-schema": "^2.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
