{
    "name": "ospp/station-simulator",
    "description": "OSPP Station Simulator — simulates 1-N self-service stations via MQTT for UAT/load testing",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel-zero/framework": "^11.0",
        "ospp/protocol": "dev-main",
        "php-mqtt/client": "^2.1",
        "react/event-loop": "^1.5",
        "react/socket": "^1.15",
        "cboden/ratchet": "^0.4",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "mockery/mockery": "^1.6"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ospp-sdk-php",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
